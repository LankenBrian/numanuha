generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  password      String?   // Hashed password for credentials provider
  name          String?
  image         String?
  plan          String    @default("free") // free, pro
  credits       Int       @default(10) // Free users get 10 credits
  usageCount    Int       @default(0) @map("usage_count")
  referralCode  String    @unique @default(cuid()) @map("referral_code")
  referredBy    String?   @map("referred_by")
  stripeCustomerId       String? @map("stripe_customer_id")
  stripeSubscriptionId   String? @map("stripe_subscription_id")
  stripePriceId          String? @map("stripe_price_id")
  stripeCurrentPeriodEnd DateTime? @map("stripe_current_period_end")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts      Account[]
  sessions      Session[]
  usageLogs     UsageLog[]
  emailVerifications EmailVerification[]
  referralsMade Referral[] @relation("Referrer")
  referralReceived Referral? @relation("Referred")
  affiliate     Affiliate?

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model EmailVerification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verifications")
}

model UsageLog {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  action      String   // remove_bg, ai_background, etc.
  status      String   // success, failed
  creditsUsed Int      @default(1) @map("credits_used")
  metadata    Json?    // Store additional info like image size, processing time
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("usage_logs")
}

model Referral {
  id          String   @id @default(cuid())
  referrerId  String   @map("referrer_id")
  referredId  String?  @unique @map("referred_id")
  code        String   @unique
  email       String?  // Email of referred user (before signup)
  status      String   @default("pending") // pending, signed_up, converted
  creditsAwarded Int   @default(0) @map("credits_awarded")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  referrer User @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referred User? @relation("Referred", fields: [referredId], references: [id], onDelete: SetNull)

  @@index([referrerId])
  @@index([code])
  @@map("referrals")
}

model Affiliate {
  id            String   @id @default(cuid())
  userId        String   @unique @map("user_id")
  code          String   @unique
  status        String   @default("pending") // pending, approved, rejected, banned
  commissionRate Decimal @default(0.30) @map("commission_rate") // 30% default
  totalSales    Decimal  @default(0) @map("total_sales")
  totalCommission Decimal @default(0) @map("total_commission")
  pendingCommission Decimal @default(0) @map("pending_commission")
  paidCommission  Decimal @default(0) @map("paid_commission")
  paypalEmail   String?  @map("paypal_email")
  website       String?
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversions AffiliateConversion[]

  @@index([code])
  @@index([status])
  @@map("affiliates")
}

model AffiliateConversion {
  id            String   @id @default(cuid())
  affiliateId   String   @map("affiliate_id")
  customerId    String   @map("customer_id")
  subscriptionId String  @map("subscription_id")
  amount        Decimal
  commission    Decimal
  status        String   @default("pending") // pending, paid, refunded, cancelled
  createdAt     DateTime @default(now()) @map("created_at")
  paidAt        DateTime? @map("paid_at")

  affiliate Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@index([affiliateId])
  @@index([status])
  @@map("affiliate_conversions")
}
