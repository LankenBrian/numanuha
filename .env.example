# AI Background Remover - Environment Variables

# Remove.bg API Key
# Get yours at: https://www.remove.bg/api
REMOVE_BG_API_KEY=your_api_key_here

# Database
# PostgreSQL connection string (Neon, Supabase, or any PostgreSQL)
# Get free PostgreSQL at: https://neon.tech
DATABASE_URL=postgresql://username:password@host:port/database?sslmode=require

# NextAuth Secret
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# Email (Resend - Recommended for transactional emails)
# Get your API key at: https://resend.com
RESEND_API_KEY=re_...
FROM_EMAIL=BG Remover Pro <noreply@yourdomain.com>

# Alternative: SMTP settings
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your_email@example.com
# SMTP_PASSWORD=your_email_password

# Stripe (for payments)
# Get your keys at: https://dashboard.stripe.com
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO=price_...

# Public
NEXT_PUBLIC_STRIPE_PRICE_ID_PRO=price_...

# AI Background Generation (Optional)
# Get your key at: https://fal.ai
FAL_API_KEY=...
